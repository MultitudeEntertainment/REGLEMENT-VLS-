/* ============================
   STYLE GLOBAL
   ============================ */

body {
    margin: 0;
    padding: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #d8eaff;
    color: #0f172a;
}

/* Mode nuit */
body.night {
    background: #0b0f19;
    color: #f1f5f9;
}

/* ============================
   FENÊTRE DE BIENVENUE
   ============================ */

#welcome-modal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
}

.welcome-box {
    background: white;
    padding: 20px;
    border-radius: 14px;
    width: 350px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.25);
}

.welcome-field {
    margin-top: 12px;
}

.welcome-field label {
    font-weight: bold;
    font-size: 14px;
}

.welcome-field input,
.welcome-field select {
    width: 100%;
    padding: 8px;
    margin-top: 4px;
    border-radius: 8px;
    border: 1px solid #bcd0ff;
}

.welcome-buttons {
    margin-top: 18px;
    display: flex;
    justify-content: space-between;
}

#welcome-guest,
#welcome-validate {
    padding: 8px 12px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    background: #2563eb;
    color: white;
    font-weight: bold;
}

/* ============================
   BARRE DU HAUT
   ============================ */

#top-bar {
    background: white;
    border-bottom: 1px solid #bcd0ff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 12px;
    position: sticky;
    top: 0;
    z-index: 999;
}

body.night #top-bar {
    background: #111827;
    border-bottom-color: #1e293b;
}

/* Logo + titre */
.logo-area {
    display: flex;
    align-items: center;
    gap: 10px;
}

#vls-logo {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    object-fit: cover;
}

.site-title {
    font-size: 18px;
    font-weight: bold;
}

/* Menu */
#main-menu {
    display: flex;
    gap: 8px;
    margin-left: 20px;
}

.menu-btn {
    padding: 6px 10px;
    border-radius: 8px;
    border: 1px solid #bcd0ff;
    background: #f1f5ff;
    cursor: pointer;
    font-size: 13px;
}

.menu-btn:hover {
    background: #dbeafe;
}

body.night .menu-btn {
    background: #1e293b;
    border-color: #334155;
    color: #f1f5f9;
}

body.night .menu-btn:hover {
    background: #334155;
}

/* ============================
   BARRE LATÉRALE INTÉGRÉE
   ============================ */

#top-sidebar {
    display: flex;
    align-items: center;
    gap: 16px;
}

/* Avatar utilisateur */
.avatar-circle {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #e2e8f0;
    object-fit: cover;
}

body.night .avatar-circle {
    background: #334155;
}

/* Profil */
.profile-area {
    display: flex;
    align-items: center;
    gap: 8px;
}

.profile-texts {
    display: flex;
    flex-direction: column;
    font-size: 12px;
}

/* Langue */
.language-area {
    display: flex;
    align-items: center;
    gap: 6px;
}

#language-select {
    padding: 4px 6px;
    border-radius: 6px;
    border: 1px solid #bcd0ff;
}

/* Heure */
.time-area {
    font-size: 12px;
    display: flex;
    flex-direction: column;
}

/* Thème */
.theme-area {
    display: flex;
    flex-direction: column;
    font-size: 12px;
}

#theme-toggle {
    margin-top: 4px;
    padding: 4px 8px;
    border-radius: 6px;
    border: none;
    background: #2563eb;
    color: white;
    cursor: pointer;
}

/* ============================
   CONTENEUR PRINCIPAL
   ============================ */

#main-container {
    max-width: 900px;
    margin: 20px auto;
    padding: 0 12px;
}

/* ============================
   PAGES
   ============================ */

.page-section {
    background: white;
    padding: 20px;
    border-radius: 14px;
    border: 1px solid #bcd0ff;
    box-shadow: 0 8px 20px rgba(0,0,0,0.12);
}

body.night .page-section {
    background: #111827;
    border-color: #1e293b;
}

/* Titres */
.page-section h1 {
    margin-top: 0;
    font-size: 22px;
}

.page-section h2 {
    margin-top: 16px;
    font-size: 18px;
}

/* Texte */
.content-box p {
    margin-top: 10px;
    line-height: 1.5;
}

/* ============================
   STAFF
   ============================ */

.staff-list {
    list-style: none;
    padding: 0;
    margin-top: 10px;
}

.staff-list li {
    margin-bottom: 6px;
    display: flex;
    justify-content: space-between;
    font-size: 14px;
}

/* ============================
   AUTRES SERVEURS
   ============================ */

.server-avatar {
    margin-top: 20px;
    text-align: center;
}

.server-avatar img {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
}

/* ============================
   PARAMÈTRES
   ============================ */

.settings-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
}

.settings-box {
    background: white;
    padding: 16px;
    border-radius: 14px;
    border: 1px solid #bcd0ff;
}

body.night .settings-box {
    background: #1e293b;
    border-color: #334155;
}

.settings-box h2 {
    margin-top: 0;
}

.settings-box input,
.settings-box select {
    width: 100%;
    padding: 8px;
    margin-top: 6px;
    border-radius: 8px;
    border: 1px solid #bcd0ff;
}

.settings-box button {
    margin-top: 10px;
    padding: 8px 12px;
    border-radius: 8px;
    border: none;
    background: #2563eb;
    color: white;
    cursor: pointer;
}

/* ============================
   FOOTER
   ============================ */

#footer {
    text-align: center;
    margin-top: 20px;
    padding: 14px;
    font-size: 13px;
    color: #475569;
}

body.night #footer {
    color: #cbd5f5;
}
